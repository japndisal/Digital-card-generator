# Copy this file to .env.local and fill in your real key.
# NEVER commit .env.local — it's already in .gitignore.

# Get your free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — defaults to gemini-2.5-flash-lite if unset.
# Current free-tier options (as of April 2026):
#   gemini-2.5-flash-lite   (stable, recommended — default)
#   gemini-3-flash-preview  (newer, preview status)
# Note: gemini-1.5-flash, gemini-2.0-flash, and gemini-2.0-flash-lite
# have all been deprecated by Google — don't use them.
GEMINI_MODEL=gemini-2.5-flash-lite
